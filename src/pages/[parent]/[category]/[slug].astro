---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import SearchPreviews from '../../../components/SearchPreviews.astro';
import Sidebar from '../../../components/Sidebar.astro';
import AtAGlance from '../../../components/docs/AtAGlance.astro';
import Badge from '../../../components/docs/Badge.astro';
import Callout from '../../../components/docs/Callout.astro';
import Card from '../../../components/docs/Card.astro';
import DecisionList from '../../../components/docs/DecisionList.astro';
import OutcomeBlock from '../../../components/docs/OutcomeBlock.astro';
import ShowcaseMeta from '../../../components/docs/ShowcaseMeta.astro';
import { mdxComponents } from '../../../components/docs/mdx-components';
import {
  docsCategoryDataMap,
  docsParentMap,
  getArticleHref,
  getCategoryHref,
  getCleanDocSlug,
  getOrderedDocsForCategory,
  getPublicDocs,
  getSearchPreviewLookup,
  getSidebarSections,
} from '../../../data/docs';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allDocs = await getCollection('docs');
  const publicDocs = getPublicDocs(allDocs);

  return publicDocs.map((doc) => ({
    params: {
      parent: docsCategoryDataMap[doc.data.category as keyof typeof docsCategoryDataMap]?.parent,
      category: doc.data.category,
      slug: getCleanDocSlug(doc.id),
    },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const allDocs = await getCollection('docs');
const publicDocs = getPublicDocs(allDocs);
const { Content, headings } = await render(doc);
const categoryData = docsCategoryDataMap[doc.data.category as keyof typeof docsCategoryDataMap];
const parent = docsParentMap[categoryData.parent as keyof typeof docsParentMap];
const pagefindCategory = categoryData?.name ?? doc.data.category;
const orderedCategoryDocs = getOrderedDocsForCategory(publicDocs, doc.data.category);
const currentDocIndex = orderedCategoryDocs.findIndex((entry) => entry.id === doc.id);
const previousDoc = currentDocIndex > 0 ? orderedCategoryDocs[currentDocIndex - 1] : undefined;
const nextDoc = currentDocIndex >= 0 ? orderedCategoryDocs[currentDocIndex + 1] : undefined;
const sidebarSections = getSidebarSections(parent.slug);
const searchPreviews = getSearchPreviewLookup(publicDocs);
const isStructuredShowcase = doc.data.category === 'case-studies' || doc.data.category === 'projects';
const thumbnailSizeMap = { sm: 64, md: 84, lg: 120 };
const thumbnailPx = thumbnailSizeMap[doc.data.thumbnailSize ?? 'md'];

// Structured showcase data sections are rendered outside the MDX body, so
// their headings are appended here to keep the "On this page" TOC complete.
const showcaseHeadings = isStructuredShowcase
  ? [
      { depth: 2, slug: 'decisions-and-trade-offs', text: 'Decisions and Trade-Offs' },
      { depth: 2, slug: 'outcome', text: 'Outcome' },
      { depth: 2, slug: 'lessons', text: 'Lessons' },
    ]
  : [];

const tocHeadings = [
  ...headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3),
  ...showcaseHeadings,
];
const articlePagefindAttributes = doc.data.hideFromSearch
  ? {
      'data-pagefind-meta': `category:${pagefindCategory}`,
      'data-pagefind-ignore': 'all',
    }
  : {
      'data-pagefind-body': true,
      'data-pagefind-meta': `category:${pagefindCategory}`,
    };
const getBadgeTone = (badge: string) => {
  const label = badge.toLowerCase();
  if (label.includes('review') || label.includes('verified')) return 'success';
  if (label.includes('ai')) return 'info';
  return 'neutral';
};

// Standardised showcase badges, gated on per-article boolean flags (default
// false, so nothing shows until the author verifies). AI-Assisted carries a
// robot icon; Reviewed carries a tick.
const showcaseBadges: Array<{ label: string; tone: 'info' | 'success'; icon: 'robot' | 'check' }> = [];
// if (doc.data.aiAssisted) showcaseBadges.push({ label: 'AI-Assisted', tone: 'info', icon: 'robot' });
// if (doc.data.reviewed) showcaseBadges.push({ label: 'Reviewed', tone: 'success', icon: 'check' });
---

<Layout
  title={`${doc.data.title} | ${categoryData?.name ?? doc.data.category}`}
  description={doc.data.description}
  ogType="article"
  updatedAt={doc.data.updatedAt}
>
  <SearchPreviews previews={searchPreviews} />

  {
    tocHeadings.length > 0 && (
      <div
        class="docs-mobile-toc-shell sticky top-[var(--docs-header-height)] z-30 border-b border-[var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-surface)_94%,transparent)] backdrop-blur lg:hidden"
        data-mobile-toc
      >
        <div class="mx-auto max-w-[1280px] px-4 md:px-8">
          <div class="docs-mobile-toc-row py-2">
            <details class="docs-mobile-toc relative block w-full">
              <summary class="docs-mobile-toc-summary flex w-full cursor-pointer list-none items-center gap-3 px-0 py-2.5 text-sm font-medium text-[var(--color-text-strong)]">
                <span class="shrink-0">On this page</span>
                <svg
                  class="docs-mobile-toc-icon h-4 w-4 shrink-0 text-[var(--color-ui-label)]"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
                </svg>
                <span
                  class="docs-mobile-toc-current min-w-0 text-sm text-[var(--color-text-strong)]"
                  data-mobile-toc-current
                >
                  {tocHeadings[0].text}
                </span>
              </summary>
              <div class="docs-mobile-toc-panel pt-2 pb-3">
                <ol class="docs-toc-list mt-0">
                  {tocHeadings.map((heading) => (
                    <li>
                      <a
                        href={`#${heading.slug}`}
                        data-toc-link={heading.slug}
                        class:list={['docs-toc-link', heading.depth === 3 && 'docs-toc-link-subheading']}
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            </details>
          </div>
        </div>
      </div>
    )
  }

  <div class="mx-auto flex max-w-[1280px] flex-col gap-10 px-4 py-10 lg:flex-row lg:px-8">
    <Sidebar sections={sidebarSections} activeCategory={doc.data.category} tocHeadings={tocHeadings} />

    <div class="min-w-0 max-w-3xl flex-1">
      <nav class="docs-breadcrumbs mb-6 flex flex-wrap items-center gap-2 text-sm text-[var(--color-text-muted)]">
        <a href="/" class="breadcrumb-link transition hover:text-[var(--color-accent)]">Home</a>
        <span>/</span>
        <a href={`/${parent.slug}`} class="breadcrumb-link transition hover:text-[var(--color-accent)]">{parent.name}</a
        >
        <span>/</span>
        <a href={getCategoryHref(doc.data.category)} class="breadcrumb-link transition hover:text-[var(--color-accent)]"
          >{categoryData?.name ?? doc.data.category}</a
        >
        <span>/</span>
        <span class="breadcrumb-current text-[var(--color-text-strong)]">{doc.data.title}</span>
      </nav>

      <article
        class="site-panel docs-article rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 sm:p-8 lg:p-10"
        {...articlePagefindAttributes}
      >
        <h1 class="flex items-start justify-between gap-4 text-4xl font-semibold tracking-tight text-[var(--color-text-strong)] lg:text-5xl">
          <span class="flex items-start gap-4 min-w-0 flex-1">
            <span class="min-w-0 flex-1">
              {doc.data.role ? doc.data.role : doc.data.title}
              {doc.data.company && <span class="block text-xl font-normal text-[var(--color-text-muted)] lg:text-2xl">{doc.data.company}</span>}
            </span>
            {doc.data.thumbnail && (
              <div class="mt-1 shrink-0 rounded-sm bg-white p-2">
                {doc.data.website
                  ? <a href={doc.data.website} target="_blank" rel="noopener noreferrer"><img src={doc.data.thumbnail.src} alt="" style={`width: ${thumbnailPx}px; max-height: 56px; height: auto; object-fit: contain; display: block`} /></a>
                  : <img src={doc.data.thumbnail.src} alt="" style={`width: ${thumbnailPx}px; max-height: 56px; height: auto; object-fit: contain; display: block`} />
                }
              </div>
            )}
          </span>
          {
            (showcaseBadges.length > 0 || doc.data.badges.length > 0) && (
              <span
                class="docs-article-badges ml-auto flex shrink-0 flex-col items-end gap-1.5 pt-1"
                aria-label="Article badges"
              >
                {showcaseBadges.map((badge) => (
                  <Badge tone={badge.tone} icon={badge.icon}>
                    <span class="text-xs leading-none">{badge.label}</span>
                  </Badge>
                ))}
                {doc.data.badges.map((badge) => (
                  <Badge tone={getBadgeTone(badge)}>
                    <span class="text-xs leading-none">{badge}</span>
                  </Badge>
                ))}
              </span>
            )
          }
        </h1>
        {
          !isStructuredShowcase && doc.data.description && (
            <p class="mt-5 max-w-2xl text-base leading-7 text-[var(--color-text)]">{doc.data.description}</p>
          )
        }

        {isStructuredShowcase && doc.data.tldr && <Callout title="TL;DR">{doc.data.tldr}</Callout>}

        {
          doc.data.heroImage && (
            <div class="mt-8 overflow-hidden rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface-muted)]">
              <Image
                src={doc.data.heroImage}
                alt=""
                class="docs-article-hero h-auto w-full"
                widths={[900, 1400]}
                sizes="(min-width: 1024px) 900px, 100vw"
              />
            </div>
          )
        }

        {
          (doc.data.author || doc.data.status || doc.data.tags.length > 0) && (
            <div class="sr-only" data-pagefind-ignore>
              {doc.data.author && (
                <span
                  data-pagefind-filter={`author:${doc.data.author}`}
                  data-pagefind-meta={`author:${doc.data.author}`}
                >
                  {doc.data.author}
                </span>
              )}
              {doc.data.status && (
                <span
                  data-pagefind-filter={`status:${doc.data.status}`}
                  data-pagefind-meta={`status:${doc.data.status}`}
                >
                  {doc.data.status}
                </span>
              )}
              {doc.data.tags.map((tag) => (
                <span data-pagefind-filter={`tag:${tag}`}>{tag}</span>
              ))}
            </div>
          )
        }

        <div class="docs-divider mt-8 border-t"></div>
        <!-- {
          isStructuredShowcase && doc.data.role && doc.data.dates && doc.data.roleSummary && (
            <ShowcaseMeta role={doc.data.role} dates={doc.data.dates} roleSummary={doc.data.roleSummary} />
          )
        } -->
        {isStructuredShowcase && doc.data.metrics && <AtAGlance metrics={doc.data.metrics} />}

        <div
          class="prose mt-8 max-w-none prose-headings:font-semibold prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:text-[var(--color-accent-hover)] prose-code:rounded prose-code:bg-[var(--color-inline-code-bg)] prose-code:px-1 prose-code:py-0.5 prose-code:text-[var(--color-inline-code-fg)] prose-pre:bg-transparent prose-pre:p-0"
        >
          <Content components={mdxComponents} />
        </div>

        {isStructuredShowcase && doc.data.decisions && <DecisionList decisions={doc.data.decisions} />}
        {
          isStructuredShowcase && doc.data.outcome && doc.data.lessons && (
            <OutcomeBlock outcome={doc.data.outcome} lessons={doc.data.lessons} />
          )
        }

        {
          doc.data.tags.length > 0 && (
            <ul class="mt-5 flex flex-wrap gap-2" aria-label="Article tags">
              {doc.data.tags.map((tag) => (
                <li>
                  <Badge>{tag}</Badge>
                </li>
              ))}
            </ul>
          )
        }

        {
          doc.data.relatedLinks.length > 0 && (
            <section class="docs-related-links mt-12 border-t border-[var(--color-border)] pt-8">
              <p class="docs-ui-label">Continue with</p>
              <div class="docs-card-grid mt-4 grid gap-4 md:grid-cols-2" data-pagefind-ignore>
                {doc.data.relatedLinks.map((link) => (
                  <Card href={link.href} title={link.title} description={link.description} eyebrow={link.eyebrow} />
                ))}
              </div>
            </section>
          )
        }

        {
          (previousDoc || nextDoc) && (
            <section class="docs-article-footer mt-12 border-t border-[var(--color-border)] pt-8">
              {(previousDoc || nextDoc) && (
                <nav class="docs-article-pagination" aria-label="Article navigation">
                  <div class="grid gap-4 md:grid-cols-2">
                    {previousDoc ? (
                      <a
                        href={getArticleHref(previousDoc.data.category, getCleanDocSlug(previousDoc.id))}
                        class="docs-article-pagination-link"
                      >
                        <span class="docs-article-pagination-label">
                          <svg class="docs-article-pagination-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <use href="/icons/docs-navigation.svg#arrow-left" />
                          </svg>
                          Previous article
                        </span>
                        <span class="docs-article-pagination-title">{previousDoc.data.title}</span>
                      </a>
                    ) : (
                      <div class="hidden md:block" />
                    )}

                    {nextDoc && (
                      <a
                        href={getArticleHref(nextDoc.data.category, getCleanDocSlug(nextDoc.id))}
                        class="docs-article-pagination-link docs-article-pagination-link-next"
                      >
                        <span class="docs-article-pagination-label">
                          Next article
                          <svg class="docs-article-pagination-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <use href="/icons/docs-navigation.svg#arrow-right" />
                          </svg>
                        </span>
                        <span class="docs-article-pagination-title">{nextDoc.data.title}</span>
                      </a>
                    )}
                  </div>
                </nav>
              )}
            </section>
          )
        }
      </article>

      {
        (doc.data.updatedAt || doc.data.editUrl) && (
          <div class="docs-article-meta mt-5 flex flex-col gap-3 px-1 sm:flex-row sm:items-center sm:justify-between">
            {doc.data.updatedAt ? (
              <p class="docs-article-meta-copy">
                Updated{' '}
                {doc.data.updatedAt.toLocaleDateString('en-US', {
                  month: 'long',
                  day: 'numeric',
                  year: 'numeric',
                })}
              </p>
            ) : (
              <div />
            )}

            {doc.data.editUrl && (
              <a href={doc.data.editUrl} target="_blank" rel="noreferrer" class="docs-article-meta-link">
                Edit this page
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</Layout>

<script>
  import '../../../scripts/article-enhancements';
</script>
