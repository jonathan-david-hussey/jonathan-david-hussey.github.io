---
import { getCollection } from 'astro:content';
import SearchPreviews from '../../../components/SearchPreviews.astro';
import Sidebar from '../../../components/Sidebar.astro';
import {
  docsCategoryDataMap,
  docsParentMap,
  getArticleHref,
  getCleanDocSlug,
  getOrderedDocsForCategory,
  getPublicDocs,
  getSearchPreviewLookup,
  getSidebarSections,
} from '../../../data/docs';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
  return Object.values(docsCategoryDataMap)
    .filter((category) => !category.hidden)
    .map((category) => ({
      params: {
        parent: category.parent,
        category: category.slug,
      },
    }));
}

const { parent: parentSlug, category } = Astro.params;
const parent = parentSlug ? docsParentMap[parentSlug as keyof typeof docsParentMap] : undefined;
const subcategory = category ? docsCategoryDataMap[category as keyof typeof docsCategoryDataMap] : undefined;
const allDocs = await getCollection('docs');
const publicDocs = getPublicDocs(allDocs);
const categoryDocs = category ? getOrderedDocsForCategory(publicDocs, category) : [];
const sections = parent ? getSidebarSections(parent.slug) : [];
const searchPreviews = getSearchPreviewLookup(publicDocs);
const isExperienceCategory = subcategory?.slug === 'experience';
const monthPattern = '(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)';
const experienceDateRangePattern = new RegExp(
  `(${monthPattern}\\s+\\d{4}\\s+[\\u2013-]\\s+(?:${monthPattern}\\s+\\d{4}|present))`,
  'i',
);

function getExperienceDateRange(body: string) {
  return body.match(experienceDateRangePattern)?.[1];
}

const categoryDocItems = categoryDocs.map((doc, index) => ({
  doc,
  index,
  dateRange: isExperienceCategory ? getExperienceDateRange(doc.body) : undefined,
}));
---

<Layout
  title={`${subcategory?.name ?? category} | ${parent?.name ?? 'Compass'}`}
  description={subcategory?.description}
>
  <SearchPreviews previews={searchPreviews} />

  <div class="mx-auto flex max-w-[1280px] flex-col gap-10 px-4 py-10 lg:flex-row lg:px-8">
    {parent && <Sidebar sections={sections} activeCategory={subcategory?.slug} />}

    <div class="min-w-0 flex-1">
      <section
        class="site-panel rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 sm:p-8 lg:p-10"
      >
        <nav class="docs-breadcrumbs mb-6 flex flex-wrap items-center gap-2 text-sm text-[var(--color-text-muted)]">
          <a href="/" class="breadcrumb-link transition hover:text-[var(--color-accent)]">Home</a>
          <span>/</span>
          {
            parent && (
              <a href={`/${parent.slug}`} class="breadcrumb-link transition hover:text-[var(--color-accent)]">
                {parent.name}
              </a>
            )
          }
          <span>/</span>
          <span class="breadcrumb-current text-[var(--color-text-strong)]">{subcategory?.name ?? category}</span>
        </nav>

        <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-text-strong)]">
          {subcategory?.name ?? category}
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-7 text-[var(--color-text)]">
          {subcategory?.description ?? 'Browse the articles in this section and jump into the topic you need.'}
        </p>

        {
          categoryDocItems.length === 0 ? (
            <div class="category-empty mt-10 rounded-[15px] bg-[var(--color-surface-muted)] px-6 py-14 text-center text-[var(--color-text-muted)]">
              No articles yet. Add MDX files in <code>src/content/docs/{category}</code> to populate this section.
            </div>
          ) : (
            <div class="docs-divider mt-10 border-t border-[var(--color-border)] pt-6">
              {
                isExperienceCategory ? (
                  <ol class="experience-list">
                    {categoryDocItems.map(({ doc, index, dateRange }) => (
                      <li>
                        <a
                          href={getArticleHref(doc.data.category, getCleanDocSlug(doc.id))}
                          class="experience-list-link"
                        >
                          <span class="experience-list-index">{String(index + 1).padStart(2, '0')}</span>
                          <span class="experience-list-main">
                            <span>
                              <span class="experience-list-role">{doc.data.title}</span>
                              {doc.data.subtitle && <span class="experience-list-company">{doc.data.subtitle}</span>}
                            </span>
                            {dateRange && <span class="experience-list-date">{dateRange}</span>}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ol>
                ) : (
                  <ol class="space-y-1">
                    {categoryDocItems.map(({ doc, index }) => (
                      <li>
                        <a
                          href={getArticleHref(doc.data.category, getCleanDocSlug(doc.id))}
                          class="docs-article-list-link grid grid-cols-[2rem_minmax(0,1fr)] items-center gap-x-3 py-2 text-sm text-[var(--color-link-subtle)] transition hover:text-[var(--color-accent)]"
                        >
                          <span class="self-center text-right text-xs font-semibold leading-none text-[var(--color-text-muted)]">
                            {String(index + 1).padStart(2, '0')}
                          </span>
                          <span class="leading-6">{doc.data.title}</span>
                        </a>
                      </li>
                    ))}
                  </ol>
                )
              }
            </div>
          )
        }
      </section>
    </div>
  </div>
</Layout>
