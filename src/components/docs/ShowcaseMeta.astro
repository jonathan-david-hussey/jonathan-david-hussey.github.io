---
interface Props {
  role: string;
  dates: string;
  roleSummary: string;
}

const { role, dates, roleSummary } = Astro.props;
---

<section
  class="not-prose my-6 rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] p-5"
  aria-label="My Role"
>
  <p class="mb-1 text-xs font-bold tracking-[0.08em] text-[var(--color-text)] uppercase">My Role</p>
  <p class="text-sm font-semibold text-[var(--color-text-strong)]">
    {role} <span class="font-normal text-[var(--color-text)]">· {dates}</span>
  </p>
  <p class="mt-2 text-sm leading-6 text-[var(--color-text)]">{roleSummary}</p>
</section>
