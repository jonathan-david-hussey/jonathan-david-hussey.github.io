---
interface Props {
  metrics: string[];
}

const { metrics } = Astro.props;
---

<section class="not-prose my-6" aria-label="At a Glance">
  <p class="mb-2 text-xs font-bold tracking-[0.08em] text-[var(--color-text)] uppercase">
    At a Glance
  </p>
  <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
    {
      metrics.map((metric) => (
        <li class="rounded-[15px] border-l-4 border-[var(--color-brand)] bg-[var(--color-hover-surface)] px-4 py-3 text-sm leading-6 text-[var(--color-text-strong)]">
          {metric}
        </li>
      ))
    }
  </ul>
</section>
