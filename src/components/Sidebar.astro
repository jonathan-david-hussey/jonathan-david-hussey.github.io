---
import type { SidebarSection } from '../data/docs';

interface Props {
  sections: SidebarSection[];
  activeCategory?: string;
  tocHeadings?: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { sections, activeCategory, tocHeadings = [] } = Astro.props;
---

<aside
  class="docs-sidebar hidden w-full shrink-0 lg:sticky lg:top-[calc(var(--docs-header-height)+1rem)] lg:block lg:max-h-[calc(100vh-var(--docs-header-height)-1.5rem)] lg:w-72 lg:overflow-y-auto lg:pr-1"
>
  <div>
    <p class="docs-ui-label">Categories</p>
    <ul class="docs-sidebar-section-list mt-5">
      {
        sections.map((section) => {
          const isActiveSection = activeCategory === section.slug;

          return (
            <li>
              <a
                href={section.href}
                aria-current={isActiveSection ? 'page' : undefined}
                class={`sidebar-link docs-sidebar-section-link block rounded-[15px] px-3 text-sm font-medium transition ${
                  isActiveSection
                    ? 'is-active text-[var(--color-accent)]'
                    : 'text-[var(--color-text)] hover:text-[var(--color-accent)]'
                }`}
              >
                {section.name}
              </a>
            </li>
          );
        })
      }
    </ul>

    {
      tocHeadings.length > 0 && (
        <nav class="docs-sidebar-toc mt-7" aria-label="Table of contents">
          <p class="docs-toc-title">On this page</p>
          <ol class="docs-toc-list docs-sidebar-toc-list">
            {tocHeadings.map((heading) => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  data-toc-link={heading.slug}
                  class:list={['docs-toc-link', heading.depth === 3 && 'docs-toc-link-subheading']}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }
  </div>
</aside>
